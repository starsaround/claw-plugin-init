{
  "name": "{{packageName}}",
  "version": "0.1.0",
  "description": "{{pluginDescription}}",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "dependencies": {
    "typebox": "1.1.39"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">={{openclawVersion}}",
      "minGatewayVersion": ">={{openclawVersion}}"
    },
    "build": {
      "openclawVersion": "{{openclawVersion}}",
      "pluginSdkVersion": "{{pluginSdkVersion}}"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": ">={{openclawVersion}}",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": ["openclaw", "plugin", "tool"],
  "license": "MIT"
}
