{
  "name": "claw-plugin-init",
  "version": "0.1.9",
  "description": "Scaffold OpenClaw Plugin projects with one command",
  "type": "module",
  "bin": {
    "claw-plugin-init": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "fmt": "prettier --write 'src/**/*.ts' 'templates/**/*'"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "mri": "^1.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starsaround/claw-plugin-init.git"
  },
  "homepage": "https://github.com/starsaround/claw-plugin-init#readme",
  "bugs": {
    "url": "https://github.com/starsaround/claw-plugin-init/issues"
  },
  "packageManager": "pnpm@10.0.0",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "openclaw",
    "claw",
    "scaffold",
    "cli",
    "plugin",
    "agent"
  ],
  "license": "MIT"
}
